flowchart LR
    %% Keep relation lines straight and readable.
    linkStyle default stroke:#0b4da2,stroke-width:3px

    subgraph UI[Renderer Process]
      HTML[electron.renderer.html]
      RJS[electron.renderer.js]
      API[window.ggdb API]
      HTML -->|bind events| RJS
      RJS -->|invoke methods| API
    end

    subgraph PRE[Preload Bridge]
      PRELOAD[electron.preload.js]
    end

    subgraph MAIN[Electron Main Process]
      IPC[ipcMain: ggdb:call]
      EMain[electron.main.js]
      BR[GGDBBridge\nfrontend/ggdb_node_bridge.js]
      EMain -->|register handler| IPC
      IPC -->|dispatch method| BR
    end

    subgraph ENGINE[C++ Engine]
      EXE[main.exe --json]
      DB[Database]
      TB[Table/Column/Rows]
      FK[ForeignKey rules]
      PERS[DatabasePersistence]
      EXE -->|execute command| DB
      DB -->|manage tables| TB
      DB -->|enforce relations| FK
      EXE -->|save/load| PERS
    end

    SNAP[(Snapshot File)]

    API -->|IPC call| PRELOAD
    PRELOAD -->|ipcRenderer.invoke| IPC
    BR -->|spawn process| EXE
    PERS <-->|read/write| SNAP
